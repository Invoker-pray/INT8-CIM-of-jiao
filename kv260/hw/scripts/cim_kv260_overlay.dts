/dts-v1/;
/plugin/;

/ {
    fragment@0 {
        target = <&fpga_full>;
        __overlay__ {
            #address-cells = <2>;
            #size-cells = <2>;
            firmware-name = "cim_soc_kv260.bit";
        };
    };

    fragment@1 {
        target = <&amba>;
        __overlay__ {
            #address-cells = <2>;
            #size-cells = <2>;

            cim_0: cim@a0000000 {
                compatible = "generic-uio";
                reg = <0x0 0xa0000000 0x0 0x4000>;
            };
        };
    };
};
